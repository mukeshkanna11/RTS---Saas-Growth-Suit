# =============================================================
# SERVER CONFIG
# =============================================================
PORT=5000
NODE_ENV=development

# =============================================================
# DATABASE
# =============================================================
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# =============================================================
# JWT AUTH
# =============================================================
JWT_SECRET=<your-strong-jwt-secret-min-32-chars>
JWT_EXPIRES=7d
JWT_REFRESH_SECRET=<your-strong-refresh-secret-min-32-chars>
JWT_REFRESH_EXPIRES=30d

# =============================================================
# FRONTEND URL
# =============================================================
CLIENT_URL=http://localhost:5173
CLIENT_URL_2=https://your-frontend.vercel.app

# =============================================================
# EMAIL CONFIG (RESEND)
# https://resend.com/api-keys
# =============================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com
COMPANY_MAIL=info@yourdomain.com

# =============================================================
# WHATSAPP API (Meta Business)
# https://developers.facebook.com/apps/
# =============================================================
WHATSAPP_TOKEN=<your-whatsapp-access-token>
WHATSAPP_PHONE_ID=<your-phone-number-id>
WHATSAPP_BUSINESS_ACCOUNT_ID=<your-business-account-id>
WHATSAPP_VERIFY_TOKEN=<your-custom-verify-token>

# =============================================================
# PAYPAL (required for subscription payments)
# https://developer.paypal.com/dashboard/applications
# =============================================================
PAYPAL_CLIENT_ID=<your-paypal-client-id>
PAYPAL_CLIENT_SECRET=<your-paypal-client-secret>
PAYPAL_WEBHOOK_ID=<your-paypal-webhook-id>
# sandbox | live
PAYPAL_MODE=sandbox

# PAYPAL_CURRENCY — Required. No default is applied in code.
#
# Sandbox:    USD
#   PayPal sandbox facilitator accounts are US-based by default.
#   INR is rejected (422 CURRENCY_NOT_SUPPORTED) unless your sandbox
#   Business account was explicitly created with Country = India.
#
# Production: INR
#   Requires a PayPal India Business account (paypal.com/in).
#   US or international PayPal accounts cannot receive INR.
#
PAYPAL_CURRENCY=INR

# EXCHANGE_RATE_INR — USD-to-INR conversion rate used by the invoice service.
#
# When PAYPAL_CURRENCY=USD (sandbox testing), payments are captured in USD.
# The invoice is still issued in INR (Indian GST compliance) using this rate.
#
# When PAYPAL_CURRENCY=INR (production with PayPal India account), the rate
# is unused — there is nothing to convert.
#
# Set this to a value close to the live mid-market rate and update it
# when the rate drifts significantly. Never hardcode this in source code.
EXCHANGE_RATE_INR=86.75

# =============================================================
# REDIS (optional — required only for subscription auto-renewal)
# Leave blank to skip BullMQ renewal job on startup.
# =============================================================
# Option A: full URL (takes priority over host/port)
# REDIS_URL=redis://:<password>@127.0.0.1:6379
# Option B: individual fields
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================
# COMPANY BRANDING (used in invoice PDFs)
# =============================================================
COMPANY_NAME=ReadyTechSolutions Pvt Ltd
COMPANY_ADDRESS=Coimbatore, Tamil Nadu, India
COMPANY_MAIL=info@readytechsolutions.in
COMPANY_PHONE=70107 97721
COMPANY_WEBSITE=https://readytechsolutions.in/
COMPANY_GSTIN=33ABCDE1234F1Z5

# =============================================================
# RATE LIMIT CONTROL
# =============================================================
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=900000

# =============================================================
# ANTHROPIC AI
# https://console.anthropic.com/settings/keys
# Generate a NEW key — never reuse a key that was ever committed
# =============================================================
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
